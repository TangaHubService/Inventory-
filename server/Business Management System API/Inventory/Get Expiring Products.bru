meta {
  name: Get Expiring Products
  type: http
  seq: 1
}

get {
  url: {{baseUrl}}/inventory/products/{{organizationId}}/expiring?days=30
  body: none
  auth: inherit
}

params:query {
  days: 30
}

settings {
  encodeUrl: true
}

docs {
  Get products that will expire within the specified number of days
}
