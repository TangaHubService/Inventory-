}

body:json {
  {
    "name": "Jane Smith",
    "email": "jane@example.com",
    "phone": "+1234567890",
    "hasInsurance": true,
    "insuranceProvider": "Blue Cross"
  }
}

settings {
  encodeUrl: true
}

docs {
  Create a new customer
}
