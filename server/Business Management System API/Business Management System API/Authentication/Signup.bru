meta {
  name: Signup
  type: http
  seq: 1
}

post {
  url: {{baseUrl}}/auth/signup
  body: json
  auth: inherit
}

headers {
  Content-Type: application/json
}

body:json {
  {
    "email": "john@example.com",
    "password": "password123",
    "name": "John Doe"
  }
}

settings {
  encodeUrl: true
}

docs {
  Register a new user with default STAFF role
}
