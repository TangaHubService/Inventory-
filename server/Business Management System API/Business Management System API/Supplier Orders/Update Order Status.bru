meta {
  name: Update Order Status
  type: http
  seq: 4
}

patch {
  url: {{baseUrl}}/organizations/{{organizationId}}/orders/order_id_here/status
  body: json
  auth: inherit
}

headers {
  Content-Type: application/json
  Authorization: Bearer {{token}}
}

body:json {
  {
    "status": "APPROVE",
    "notes": "Approved by manager"
  }
}

settings {
  encodeUrl: true
}
