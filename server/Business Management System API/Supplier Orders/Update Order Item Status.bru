meta {
  name: Update Order Item Status
  type: http
  seq: 5
}

patch {
  url: {{baseUrl}}/organizations/{{organizationId}}/orders/order_id_here/items/item_id_here/status
  body: json
  auth: inherit
}

headers {
  Content-Type: application/json
  Authorization: Bearer {{token}}
}

body:json {
  {
    "status": "FULFILLED",
    "receivedQuantity": 10,
    "notes": "Received in good condition"
  }
}

settings {
  encodeUrl: true
}
