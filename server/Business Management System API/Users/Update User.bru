meta {
  name: Update User
  type: http
  seq: 3
}

put {
  url: {{baseUrl}}/users/:id
  body: json
  auth: inherit
}

params:path {
  id: user-id
}

headers {
  Content-Type: application/json
}

body:json {
  {
    "name": "Updated Name",
    "email": "newemail@example.com"
  }
}

settings {
  encodeUrl: true
}

docs {
  Update user details
}
