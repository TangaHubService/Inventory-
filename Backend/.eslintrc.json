{
  "root": true,
  "parser": "@typescript-eslint/parser",
  "parserOptions": {
    "ecmaVersion": 2020,
    "sourceType": "module",
    "project": "./tsconfig.eslint.json",
    "tsconfigRootDir": "."
  },
  "extends": ["eslint:recommended"],
  "env": {
    "node": true,
    "es2020": true
  },
  "globals": {
    "describe": "readonly",
    "it": "readonly",
    "expect": "readonly",
    "vi": "readonly"
  },
  "ignorePatterns": ["dist/", "node_modules/", "prisma/migrations/", "backups/"],
  "rules": {
    "no-unused-vars": ["warn", { "argsIgnorePattern": "^_" }],
    "no-undef": "off",
    "no-case-declarations": "off",
    "no-useless-escape": "off"
  }
}
