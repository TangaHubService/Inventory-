# RRA EBM / VSDC (obtain spec and URLs from RRA cis_sdc_certification@rra.gov.rw)
ENABLE_EBM=false
EBM_API_URL=
EBM_API_KEY=
EBM_API_SECRET=
EBM_ENVIRONMENT=sandbox
EBM_SALE_PATH=/sales
EBM_REFUND_PATH=/refunds
EBM_VOID_PATH=/voids
EBM_REQUEST_TIMEOUT_MS=30000
EBM_USE_MOCK=false
EBM_MAX_QUEUE_RETRIES=10
