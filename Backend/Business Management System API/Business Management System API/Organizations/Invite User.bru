meta {
  name: Invite User
  type: http
  seq: 6
}

post {
  url: {{baseUrl}}/organizations/{{organizationId}}/invite
  body: json
  auth: inherit
}

headers {
  Content-Type: application/json
}

body:json {
  {
    "email": "newuser@example.com",
    "role": "STAFF",
    "defaultPassword": "temp123"
  }
}

settings {
  encodeUrl: true
}

docs {
  Invite a user to the organization. Roles: ADMIN, MANAGER, ACCOUNTANT, STAFF
}
