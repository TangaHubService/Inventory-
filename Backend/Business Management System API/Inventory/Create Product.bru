    "quantity": 100,
    "unitPrice": 5.50,
    "expiryDate": "2025-12-31",
    "category": "Pain Relief",
    "hasExpiry": true
  }
}

settings {
  encodeUrl: true
}

docs {
  Create a new product. Set hasExpiry to false for non-perishable items
}
