meta {
  name: Create Sale
  type: http
  seq: 1
}

post {
  url: {{baseUrl}}/sales
  body: json
  auth: inherit
}

headers {
  Content-Type: application/json
}

body:json {
  {
    "customerId": "customer-id",
    "items": [
      {
        "productId": "product-id",
        "quantity": 2,
        "unitPrice": 10.50
      }
    ],
    "paymentType": "CASH",
    "cashAmount": 21.00,
    "insuranceAmount": 0
  }
}

settings {
  encodeUrl: true
}

docs {
  Create a new sale transaction
}
