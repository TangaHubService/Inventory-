meta {
  name: Bulk Invite Users (Excel)
  type: http
  seq: 7
}

post {
  url: {{baseUrl}}/organizations/{{organizationId}}/invite/bulk
  body: multipartForm
  auth: inherit
}

body:multipart-form {
  file: @file(/path/to/users.xlsx)
}

settings {
  encodeUrl: true
}

docs {
  Bulk invite users via Excel file upload
}
